{
  "name": "agent-notify-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "mkdir -p public/assets && bun build ./src/client/main.tsx --outfile ./public/assets/app.js --target browser --format esm --minify",
    "build": "bun run build:client",
    "dev": "bun run build:client && bun run ./src/server/index.ts",
    "start": "bun run ./src/server/index.ts",
    "test": "bun test",
    "setup-hooks": "bash ./scripts/setup-hooks.sh"
  },
  "dependencies": {
    "hono": "^4.8.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "bun-types": "^1.3.3",
    "typescript": "^5.9.3"
  }
}
